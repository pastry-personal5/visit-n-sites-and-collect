#!/usr/bin/env bash
set -x

SCRIPT_DIR=$(dirname "$(readlink -f "$0")")
ENCRYPTED_GLOBAL_CONFIG_FILE_PATH=${SCRIPT_DIR}/config/global_config.yaml.gpg
DECRYPTED_GLOBAL_CONFIG_FILE_PATH=${SCRIPT_DIR}/config/global_config.yaml

DECRYPTED_PREEXISTED=0
if [[ -f ${DECRYPTED_GLOBAL_CONFIG_FILE_PATH} ]]; then
    DECRYPTED_PREEXISTED=1
fi

if [[ -f ${ENCRYPTED_GLOBAL_CONFIG_FILE_PATH} ]]; then
    gpg -o ${DECRYPTED_GLOBAL_CONFIG_FILE_PATH} -d ${ENCRYPTED_GLOBAL_CONFIG_FILE_PATH}
    if [[ ${DECRYPTED_PREEXISTED} -eq 0 ]]; then
        trap 'rm -f "${DECRYPTED_GLOBAL_CONFIG_FILE_PATH}"' EXIT
    fi
fi

export PYTHONPATH="${SCRIPT_DIR}/src${PYTHONPATH:+:$PYTHONPATH}"
uv run --python 3.11 python -m visit_n_sites_and_collect.main
